//
// FIDIUS-I-0027 (E2): a sandboxed connector making an OUTBOUND HTTP GET via
// wasi:http@0.2.6 (vendored to match the host's wasmtime-wasi-http 45). Egress
// is host-gated (http capability + embedder EgressPolicy).
package fidius:fetcher@1.0.0;

interface fetcher {
    fetch: func(url: string) -> string;
    /// Interface-hash carrier (parity with fidius plugins) — lets the high-level
    /// `PluginHost::load_wasm` path load this fixture as a package.
    fidius-interface-hash: func() -> u64;
}

world fetcher-plugin {
    import wasi:http/outgoing-handler@0.2.6;
    export fetcher;
}
